# Hugging Face User Access Token (Required for gated models like Llama 3.2)
HF_TOKEN=your_hugging_face_token_here

# ── Kernel backend toggles ───────────────────────────────────────────────────
# When true, ops dispatch to the fused Triton kernels in kernels/.
# When false, fall back to the pure-PyTorch reference implementations.
# Useful for debugging numerical issues or comparing perf side-by-side.
USE_TRITON=true
