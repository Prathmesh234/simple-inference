# Hugging Face User Access Token (Required for gated models like Llama 3.2)
HF_TOKEN=your_hugging_face_token_here

# ── Kernel backend toggles ───────────────────────────────────────────────────
# When true, ops dispatch to the fused Triton kernels in kernels/.
# When false, fall back to the pure-PyTorch reference implementations.
# Useful for debugging numerical issues or comparing perf side-by-side.
USE_TRITON=true

# Enable Triton autotuning for the fused kernels.
# Set to false to force the first config only (useful for reproducible debug runs).
USE_AUTOTUNE=true

# Fuse the attention transpose path in ops/attention.py.
# Set to false to keep the explicit transpose path for debugging.
FUSE=true

# Wrap the model forward with torch.compile to cut per-step CPU overhead
# (fewer kernel launches via Inductor fusion). Off by default so eager stays
# the baseline. Biggest win is usually with USE_TRITON=false, which lets
# Inductor fuse the pure-PyTorch op path instead of calling the hand-written
# Triton kernels as opaque ops.
USE_COMPILE=false

# torch.compile mode when USE_COMPILE=true: "default", "reduce-overhead",
# or "max-autotune". "default" uses torch.compile's own default mode.
COMPILE_MODE=default

# Capture the autoregressive decode step into a custom torch.cuda.CUDAGraph and
# replay it per token, collapsing hundreds of per-op kernel launches into one
# replay (the main driver of decode CPU overhead). Prefill stays eager. Works
# alongside the custom Triton kernels (USE_TRITON=true) — only attention swaps
# to a masked full-cache SDPA so a single fixed-shape graph can serve every
# decode position. Off by default.
USE_CUDA_GRAPHS=false
